      ]
    },
    "LifecyclePolicy": {
      "allOf": [
        {
          "$ref": "#/components/schemas/LifecyclePolicy"
        },
        {
          "description": "The object lifecycle policy to apply to the container."
        }
      ]
    }
  },
  "required": [
    "ContainerName",
    "LifecyclePolicy"
  ]
}